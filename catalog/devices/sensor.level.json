    { "name": "euMin", "type": "float", "default": 0.0, "min": -1000, "max": 1000 },
    { "name": "euMax", "type": "float", "default": 100.0, "min": -1000, "max": 1000 },
    { "name": "euUnit", "type": "string", "default": "%" }
  ]
}
