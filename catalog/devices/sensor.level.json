{
  "typeId": "sensor.level",
  "category": "Sensor",
  "displayName": "Sensor de nível",
  "behavior": "level-sensor",
  "visualScene": "res://assets/devices/sensor.height.tscn",
  "ports": [
    { "portName": "level", "direction": "In", "type": "Word" }
