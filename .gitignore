# Godot
.godot/
*.translation
export_credentials.cfg

# .import é regenerado por `godot --headless --import` (o CI faz isso);
# versioná-lo só geraria conflito a cada reimportação.
*.import

# .NET
bin/
obj/
*.user
*.suo
packages/
TestResults/

# Build/export: saídas fora, script de empacotamento dentro
build/*
!build/package.ps1
*.zip

# OS/editor
.DS_Store
Thumbs.db
*.tmp
*.swp
.vscode/
.idea/

# Claude Code — só arquivos locais/credenciais; skills são versionadas
.claude/settings.local.json
.claude/*.local.json
.claude/.credentials.json

# Godot gera .uid para todo .cs; os de tests/ nao sao usados pelo engine
tests/**/*.cs.uid

# Compilador STruC++ extraído do OpenPLC Editor instalado (regerável por
# tools/openplc-validate/validar.ps1 — nunca versionar código de terceiros)
tools/openplc-validate/.strucpp/
